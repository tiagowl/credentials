# Database — Neon PostgreSQL
# Pooled connection (app runtime / Prisma Client)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection (migrations / db push — sem "-pooler" no host)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Session — minimum 32 random characters
SESSION_SECRET="change-me-to-a-random-32-char-secret-key"

# Encryption — fixed salt for PBKDF2 key derivation (do not change after setup)
# Para dados de teste do seed.sql, use: credentials-vault-seed-salt-2026
ENCRYPTION_SALT="change-me-to-a-random-encryption-salt-value"

# Environment
NODE_ENV="development"

# Optional — default session timeout in minutes (overridden by VaultConfig)
DEFAULT_SESSION_TIMEOUT="15"
